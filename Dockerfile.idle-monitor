FROM python:3.13-slim

WORKDIR /app

# Install only the runtime dependencies needed by the idle monitor
RUN pip install --no-cache-dir \
    boto3>=1.35.0 \
    prometheus_client>=0.21.0

# Copy the control plane package
COPY discord_control_plane/ /app/discord_control_plane/

# Expose metrics port
EXPOSE 8000

# Run the idle monitor
ENTRYPOINT ["python", "-m", "discord_control_plane.handlers.idle_monitor"]
